{
  "consumer": {
    "name": "delivery-service"
  },
  "interactions": [
    {
      "description": "POST request for Max's address",
      "key": "a7dd1631",
      "pending": false,
      "providerStates": [
        {
          "name": "Three customers"
        }
      ],
      "request": {
        "body": {
          "content": {
            "city": "26122 Oldenburg",
            "recipient": "Max Mustermann",
            "street": {
              "name": "Poststrasse",
              "number": "1"
            }
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "header": {
            "Content-Type": {
              "combine": "AND",
              "matchers": [
