      "type": "Synchronous/HTTP"
    },
    {
      "description": "POST request for Sherlock's address",
      "key": "a0ca8204",
      "pending": false,
      "providerStates": [
        {
          "name": "Three customers"
        }
      ],
      "request": {
        "body": {
          "content": {
            "city": "London NW1 6XE",
            "recipient": "Sherlock Holmes",
            "street": {
              "name": "Baker Street",
              "number": "221B"
            }
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "header": {
            "Content-Type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "application/json.*"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/valid-addresses"
      },
      "response": {
        "body": {
          "content": {
            "detail": "Addresses from UK are not supported for delivery"
          },
          "contentType": "application/problem+json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/problem+json"
          ]
        },
        "matchingRules": {
          "body": {
            "$.detail": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": ".*"
                }
              ]
            }
          },
          "header": {
            "Content-Type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "application/problem\\+json.*"
                }
              ]
            }
          }
        },
        "status": 400
      },
      "transport": "http",
      "type": "Synchronous/HTTP"
    }
  ],
  "metadata": {
    "pact-jvm": {
      "version": "4.6.15"
